# =============================================================================
# Tarannum AI Platform - Milestone 4 Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values
# For Railway deployment, set these in Railway Dashboard → Variables
# =============================================================================

# -----------------------------------------------------------------------------
# PRODUCTION ENVIRONMENT
# -----------------------------------------------------------------------------
ENVIRONMENT=production
# Options: development, staging, production
# production: Full security, rate limiting, no debug logs
# development: Debug mode, relaxed security

DEBUG=false
# Set to true only for local development
# NEVER set to true in production

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
# Option 1: Full connection string (recommended for Railway/cloud)
DATABASE_URL=postgresql+psycopg2://user:password@host:port/database

# Option 2: Individual components (if DATABASE_URL not provided)
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tarannum_db

# -----------------------------------------------------------------------------
# SECURITY & AUTHENTICATION
# -----------------------------------------------------------------------------
SECRET_KEY=your-very-long-random-secret-key-minimum-32-characters-change-this-in-production
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
# This is used for JWT token signing - MUST be unique and secret

# -----------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed frontend origins
# For Railway + Vercel: Add your Vercel app URL(s)
# Example: https://your-app.vercel.app,https://www.your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-app.vercel.app
# For development: http://localhost:3000,http://localhost:5173
# For production: Replace with your actual Vercel domain(s)

# -----------------------------------------------------------------------------
# RATE LIMITING (Milestone 4)
# -----------------------------------------------------------------------------
ENABLE_RATE_LIMITING=true
# Enable rate limiting middleware
# Set to false only for development/testing

RATE_LIMIT_PER_MINUTE=120
# Maximum requests per minute per IP address

RATE_LIMIT_PER_HOUR=5000
# Maximum requests per hour per IP address

RATE_LIMIT_BURST=30
# Separate allowance for public, read-only classroom traffic sharing one public IP.
RATE_LIMIT_SAFE_READ_PER_MINUTE=1200
RATE_LIMIT_SAFE_READ_PER_HOUR=20000
RATE_LIMIT_SAFE_READ_BURST=300
# Maximum requests allowed in a 10-second burst window

RATE_LIMIT_EXCLUDE_LOCALHOST=true
# Set to true to exclude localhost from rate limiting (development)
# Set to false in production

# -----------------------------------------------------------------------------
# REDIS & ASYNC PROCESSING (Milestone 4 - Optional)
# -----------------------------------------------------------------------------
# Redis is used for Celery task queue (background audio processing)
# Only needed if you want async processing (recommended for production)

REDIS_URL=redis://localhost:6379/0
# For Railway: Get from Railway Redis service → Variables → REDIS_URL
# Format: redis://default:password@host:port/db
# Leave empty if not using Redis (synchronous processing will be used)

USE_ASYNC_PROCESSING=false
# Set to true if you have Redis configured and want background processing
# false = synchronous (current request waits for processing)
# true = asynchronous (request returns immediately, processing in background)

# -----------------------------------------------------------------------------
# CLOUD STORAGE (Milestone 4 - Optional)
# -----------------------------------------------------------------------------
# Cloud storage for audio files (reference recordings, student sessions)
# If not configured, files will be stored locally (Railway volumes)

CLOUD_STORAGE_TYPE=local
# Options: local, s3, azure, gcs
# local = Use local file system (Railway volumes)
# s3 = AWS S3 (requires AWS credentials below)
# azure = Azure Blob Storage (not implemented yet)
# gcs = Google Cloud Storage (not implemented yet)

# AWS S3 Configuration (only if CLOUD_STORAGE_TYPE=s3)
S3_BUCKET_NAME=tarannum-prod-audio
# Your S3 bucket name

AWS_ACCESS_KEY_ID=your_aws_access_key_id
# AWS IAM user access key

AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# AWS IAM user secret key

AWS_REGION=us-east-1
# AWS region where your S3 bucket is located
# Examples: us-east-1, us-west-2, eu-west-1

# -----------------------------------------------------------------------------
# VOSK MODEL CONFIGURATION
# -----------------------------------------------------------------------------
# Speech recognition model for Arabic text extraction

VOSK_MODEL_PATH=./models
# Local path where Vosk model is stored
# Default: ./models (relative to backend directory)

VOSK_MODEL_DOWNLOAD_URL=
# Optional: URL to download model if not present
# Leave empty to disable auto-download

AUTO_DOWNLOAD_MODEL=false
# Set to true to automatically download model if not found
# Recommended: false (download manually or use Railway build step)

VOSK_MODEL_TYPE=ar-mgb2
# Model type to download if AUTO_DOWNLOAD_MODEL=true
# Options: ar-mgb2 (smaller, faster), ar-mgb3 (larger, more accurate)

# -----------------------------------------------------------------------------
# API & DOMAIN CONFIGURATION
# -----------------------------------------------------------------------------
# Your production API URL (for frontend configuration)
# This is set in Vercel, not here - but documented for reference
# VITE_API_URL=https://your-api.up.railway.app

DOMAIN=yourdomain.com
# Your production domain (if using custom domain)
# Used for generating absolute URLs in emails/notifications

API_URL=https://your-api.up.railway.app
# Your Railway backend API URL
# Used internally for generating URLs

# -----------------------------------------------------------------------------
# LOGGING & MONITORING
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Use INFO or WARNING in production, DEBUG only for troubleshooting

# -----------------------------------------------------------------------------
# FILE UPLOAD LIMITS
# -----------------------------------------------------------------------------
MAX_FILE_SIZE_MB=100
# Maximum audio file size in megabytes
# Default: 100 MB

# -----------------------------------------------------------------------------
# SUBSCRIPTION & COMMISSION (Milestone 4)
# -----------------------------------------------------------------------------
# These are handled by the subscription_service.py
# No environment variables needed - configured in database
# Commission rates are set per Qari in the database

# -----------------------------------------------------------------------------
# NOTES FOR RAILWAY DEPLOYMENT
# -----------------------------------------------------------------------------
# 1. Set all variables in Railway Dashboard → Your Service → Variables
# 2. Required variables:
#    - DATABASE_URL (from Railway Postgres service)
#    - SECRET_KEY (generate a secure random string)
#    - ENVIRONMENT=production
#    - DEBUG=false
#    - ALLOWED_ORIGINS (your Vercel frontend URL)
# 3. Optional but recommended:
#    - Rate limiting variables
#    - Redis variables (if using async processing)
#    - S3 variables (if using cloud storage)
# 4. After setting variables, redeploy your service

# -----------------------------------------------------------------------------
# NOTES FOR VERCEL DEPLOYMENT (Frontend)
# -----------------------------------------------------------------------------
# Set in Vercel Dashboard → Project → Settings → Environment Variables:
# - VITE_API_URL=https://your-api.up.railway.app
#   (Replace with your actual Railway backend URL)

# =============================================================================
# END OF ENVIRONMENT VARIABLES
# =============================================================================
