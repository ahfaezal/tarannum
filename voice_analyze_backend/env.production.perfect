# =============================================================================
# Tarannum AI Platform - Perfect Production Environment Variables
# =============================================================================
# Copy this file to .env and replace placeholder values with your actual values
# For Railway: Set these in Railway Dashboard → Variables (not .env file)
# =============================================================================

# -----------------------------------------------------------------------------
# PRODUCTION ENVIRONMENT (REQUIRED)
# -----------------------------------------------------------------------------
ENVIRONMENT=production
DEBUG=false

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION (REQUIRED)
# -----------------------------------------------------------------------------
# PostgreSQL connection string - works with ANY PostgreSQL database:
# - Railway Postgres: Get from Railway → Postgres Service → Variables → DATABASE_URL
# - Supabase: Get from Supabase Dashboard → Project Settings → Database → Connection String
# - AWS RDS: Format: postgresql+psycopg2://user:pass@host:5432/dbname
# - Local PostgreSQL: postgresql+psycopg2://user:pass@localhost:5432/dbname
# - Other cloud providers: Use their provided connection string
#
# Format: postgresql+psycopg2://username:password@host:port/database_name
DATABASE_URL=postgresql+psycopg2://postgres:password@host:port/database_name

# -----------------------------------------------------------------------------
# SECURITY & AUTHENTICATION (REQUIRED)
# -----------------------------------------------------------------------------
# Generate secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
# MUST be minimum 32 characters
SECRET_KEY=CHANGE-THIS-TO-A-RANDOM-32-PLUS-CHARACTER-STRING-IN-PRODUCTION

# -----------------------------------------------------------------------------
# CORS CONFIGURATION (REQUIRED)
# -----------------------------------------------------------------------------
# Your Vercel frontend URL - CRITICAL for frontend to work
# Format: https://your-app.vercel.app
# Multiple URLs: https://app1.vercel.app,https://app2.vercel.app
ALLOWED_ORIGINS=https://voice-analyze-frontend-lsyr.vercel.app

# -----------------------------------------------------------------------------
# RATE LIMITING (RECOMMENDED - Milestone 4)
# -----------------------------------------------------------------------------
ENABLE_RATE_LIMITING=true
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_PER_HOUR=5000
RATE_LIMIT_BURST=30
RATE_LIMIT_EXCLUDE_LOCALHOST=false

# -----------------------------------------------------------------------------
# REDIS & ASYNC PROCESSING (OPTIONAL - Milestone 4)
# -----------------------------------------------------------------------------
# Get from: Railway → Redis Service → Variables → REDIS_URL
# Format: redis://default:password@host:port/db
REDIS_URL=redis://default:xeOCZUCvXjoRshCCPQYIYJuUHJpEnOwR@gondola.proxy.rlwy.net:12072

# Enable background processing (requires Redis)
USE_ASYNC_PROCESSING=true

# -----------------------------------------------------------------------------
# CLOUD STORAGE (OPTIONAL - Milestone 4)
# -----------------------------------------------------------------------------
# Options: local, s3
# Use 'local' for Railway volumes, 's3' for AWS S3
CLOUD_STORAGE_TYPE=local

# AWS S3 Configuration (only if CLOUD_STORAGE_TYPE=s3)
# S3_BUCKET_NAME=tarannum-prod-audio
# AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# VOSK MODEL CONFIGURATION (OPTIONAL)
# -----------------------------------------------------------------------------
VOSK_MODEL_PATH=./models
VOSK_MODEL_DOWNLOAD_URL=
AUTO_DOWNLOAD_MODEL=false
VOSK_MODEL_TYPE=ar-mgb2

# -----------------------------------------------------------------------------
# API & DOMAIN CONFIGURATION (OPTIONAL)
# -----------------------------------------------------------------------------
DOMAIN=yourdomain.com
API_URL=https://tarannum-backend-production.up.railway.app

# =============================================================================
# QUICK SETUP CHECKLIST
# =============================================================================
# 1. Copy this file to .env (for local testing)
# 2. Replace DATABASE_URL with your Railway Postgres URL
# 3. Generate and set SECRET_KEY (min 32 chars)
# 4. Set ALLOWED_ORIGINS to your Vercel frontend URL
# 5. Set REDIS_URL if using Redis (from Railway Redis service)
# 6. For Railway: Set these in Railway Dashboard → Variables (not .env file)
# 7. For Vercel: Set VITE_API_URL = your Railway backend URL
# =============================================================================
